menu "Weather Service"

    config WEATHER_WIFI_SSID
        string "Wi-Fi SSID"
        default ""

    config WEATHER_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""

    config WEATHER_QWEATHER_KEY
        string "QWeather API key"
        default ""
        help
            Get a key from https://console.qweather.com/

    config WEATHER_LOCATION
        string "QWeather location"
        default "101020100"
        help
            QWeather LocationID or longitude,latitude, for example 101020100 or 121.47,31.23.

    config WEATHER_LANGUAGE
        string "QWeather language"
        default "en"
        help
            Use en for this built-in bitmap font UI. zh works for API data but this UI cannot draw Chinese glyphs.

    config WEATHER_REFRESH_INTERVAL_MIN
        int "Weather refresh interval in minutes"
        default 60
        range 5 1440

endmenu
